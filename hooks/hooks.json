{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"(npm run dev|pnpm dev|yarn dev)\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] 注意: dev serverはtmuxで実行することを推奨します' >&2; echo '[Hook] tmux new-session -d -s dev \"npm run dev\"' >&2"
          }
        ],
        "description": "dev serverをtmuxで実行するよう推奨"
      },
      {
        "matcher": "tool == \"Write\" && tool_input.file_path matches \"\\\\.(md|txt)$\" && !(tool_input.file_path matches \"(README|CLAUDE|CONTRIBUTING|CHANGELOG)\\\\.md$\")",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] 警告: 不要なドキュメントファイルの作成を検出' >&2; echo '[Hook] README.mdに追記することを検討してください' >&2"
          }
        ],
        "description": "不要なドキュメントファイル作成を警告"
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git push --force\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCKED] force pushは禁止されています' >&2; exit 2"
          }
        ],
        "description": "force pushをブロック"
      },
      {
        "matcher": "(tool == \"Read\" || tool == \"Bash\") && (tool_input.file_path matches \"\\\\.env$\" || tool_input.command matches \"cat.*\\\\.env|head.*\\\\.env|tail.*\\\\.env|less.*\\\\.env|more.*\\\\.env\")",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCKED] 平文.envファイルの直接読み取りは禁止です。SOPS経由で操作してください' >&2; exit 2"
          }
        ],
        "description": ".envファイル直接読み取りをブロック（SOPS経由を強制）"
      },
      {
        "matcher": "(tool == \"Edit\" || tool == \"Write\") && tool_input.file_path matches \"(main\\\\.cf|master\\\\.cf|dovecot|opendkim)\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[BLOCKED] メールサーバー設定の変更は禁止です。rules/mail-server.md を参照してください' >&2; exit 2"
          }
        ],
        "description": "メールサーバー設定変更をブロック"
      },
      {
        "matcher": "(tool == \"Edit\" || tool == \"Write\") && tool_input.file_path matches \"/etc/(ssh|fail2ban|apache2|systemd)/\"",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] 警告: システム設定ファイルの変更を検出。ユーザーに確認してください' >&2"
          }
        ],
        "description": "システム設定変更を警告"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/suggest-compact.js"
          }
        ],
        "description": "ツール呼び出し回数を追跡し、適切なタイミングで/compactを推奨"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/pre-bash-git-push-reminder.js"
          }
        ],
        "description": "git push前に変更内容のレビューをリマインド"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/audit-trail.js",
            "timeout": 3
          }
        ],
        "description": "全ツール実行をSHA-256ハッシュチェーン付き監査証跡に記録"
      },
      {
        "matcher": "tool == \"Edit\" || tool == \"Write\"",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/scripts/agent-trace.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash /root/.claude/scripts/activity-log.sh tool-use",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "bash /root/.claude/scripts/dashboard-update.sh",
            "timeout": 3
          }
        ],
        "description": "Agent Trace + Activity Log + Dashboard"
      },
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.(ts|tsx|js|jsx)$\"",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const i=JSON.parse(d);const p=i.tool_input?.file_path;if(p&&fs.existsSync(p)){const c=fs.readFileSync(p,'utf8');if(/console\\.log/.test(c)){console.error('[Hook] 警告: console.logが残っています');console.error('[Hook] コミット前に削除してください')}}console.log(d)})\""
          }
        ],
        "description": "console.logを警告"
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"gh pr create\"",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const i=JSON.parse(d);const out=i.tool_output?.output||'';const m=out.match(/https:\\/\\/github.com\\/[^\\\\s]+/);if(m){console.error('[Hook] PR作成完了: '+m[0])}console.log(d)})\""
          }
        ],
        "description": "PR作成時にURLを表示"
      },
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.ts$\"",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const{execSync}=require('child_process');const fs=require('fs');const path=require('path');let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const i=JSON.parse(d);const p=i.tool_input?.file_path;if(p&&fs.existsSync(p)){let dir=path.dirname(p);while(dir!==path.dirname(dir)&&!fs.existsSync(path.join(dir,'tsconfig.json'))){dir=path.dirname(dir)}if(fs.existsSync(path.join(dir,'tsconfig.json'))){try{execSync('npx tsc --noEmit --pretty false 2>&1',{cwd:dir,encoding:'utf8',stdio:['pipe','pipe','pipe']})}catch(e){const lines=(e.stdout||'').split('\\n').filter(l=>l.includes(p)).slice(0,5);if(lines.length){console.error('[Hook] 型エラー:');lines.forEach(l=>console.error(l))}}}}console.log(d)})\""
          }
        ],
        "description": "TypeScriptファイル編集後に型チェック"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/post-bash-build-complete.js",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "ビルド完了後にバックグラウンドで分析を実行"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/quality-gate.js",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "ファイル編集後にクオリティゲートチェックを実行"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/post-edit-format.js"
          }
        ],
        "description": "JS/TSファイル編集後にBiome/Prettierで自動フォーマット"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/session-start.js"
          }
        ],
        "description": "セッション開始時に前回のコンテキストを読み込み、プロジェクト情報を検出"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/memory-recall.js",
            "timeout": 10
          }
        ],
        "description": "セッション開始時にLanceDBから重要な記憶を自動想起してコンテキストに注入"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/pre-compact.js"
          }
        ],
        "description": "コンテキスト圧縮前に状態を保存"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/session-end.js",
            "timeout": 10
          }
        ],
        "description": "各レスポンス後にセッション状態を永続化"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/evaluate-session.js",
            "timeout": 10
          }
        ],
        "description": "セッションから抽出可能なパターンを評価"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/memory-capture.js",
            "timeout": 15
          }
        ],
        "description": "会話からキーワードを検出し、記憶をLanceDBに自動保存"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/cost-tracker.js",
            "timeout": 10
          }
        ],
        "description": "トークン使用量とコストを追跡（~/.claude/metrics/costs.jsonl）"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/check-console-log.js"
          }
        ],
        "description": "変更ファイル内のconsole.logを最終チェック"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /root/.claude/scripts/agent-trace-finalize.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /root/.claude/scripts/activity-log.sh session-end",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "bash /root/.claude/scripts/dashboard-update.sh --session-end",
            "timeout": 3
          }
        ],
        "description": "Agent Trace + Activity Log + Dashboard: Finalize"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] セッション終了: パターンを記録しました' >&2"
          }
        ],
        "description": "セッション終了時にパターンを記録"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node /root/.claude/scripts/hooks/session-end-marker.js"
          }
        ],
        "description": "セッション終了ライフサイクルマーカー"
      }
    ]
  }
}
